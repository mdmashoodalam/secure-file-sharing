{
  "info": {
    "name": "Secure File Sharing API",
    "description": "Complete API test collection for the Secure File Sharing Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Automatically save the token after login",
                  "var resp = pm.response.json();",
                  "if (resp.success && resp.data && resp.data.token) {",
                  "  pm.collectionVariables.set('token', resp.data.token);",
                  "  console.log('Token saved:', resp.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/your/test/file.pdf",
                  "description": "Select any allowed file (PDF, image, etc)"
                }
              ]
            },
            "url": "{{base_url}}/files/upload"
          }
        },
        {
          "name": "Get My Files",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/files/my-files"
          }
        },
        {
          "name": "Download File",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/files/download/1"
          }
        },
        {
          "name": "Share File",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileId\": 1,\n  \"shareWithEmail\": \"anotheruser@example.com\",\n  \"permission\": \"DOWNLOAD\"\n}"
            },
            "url": "{{base_url}}/files/share"
          }
        },
        {
          "name": "Get Shared With Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/files/shared-with-me"
          }
        },
        {
          "name": "Generate Download Link",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/files/generate-link/1"
          }
        },
        {
          "name": "Download by Token (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/files/download/public?token=YOUR_TOKEN_HERE",
              "host": ["{{base_url}}"],
              "path": ["files", "download", "public"],
              "query": [{ "key": "token", "value": "YOUR_TOKEN_HERE" }]
            }
          }
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/files/1"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/admin/users"
          }
        },
        {
          "name": "Update User Role (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/2/role?role=ROLE_ADMIN",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "2", "role"],
              "query": [{ "key": "role", "value": "ROLE_ADMIN" }]
            }
          }
        },
        {
          "name": "Get All Files (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/files/all"
          }
        }
      ]
    }
  ]
}
